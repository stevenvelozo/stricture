{
	"name": "stricture",
	"version": "4.0.1",
	"description": "Stricture MicroDDL JSON Parser — compiler and multi-target schema code generator",
	"main": "source/Stricture.js",
	"bin": {
		"stricture": "./bin/stricture"
	},
	"scripts": {
		"start": "node bin/stricture",
		"coverage": "npx quack coverage",
		"test": "npx quack test",
		"tests": "npx quack test -g",
		"build": "npx quack build",
		"docker-dev-build": "docker build ./ -f Dockerfile_LUXURYCode -t stricture-image:local",
		"docker-dev-run": "docker run -it -d --name stricture-dev -p 17715:8080 -p 13154:8086 -v \"$PWD/.config:/home/coder/.config\"  -v \"$PWD:/home/coder/stricture\" -u \"$(id -u):$(id -g)\" -e \"DOCKER_USER=$USER\" stricture-image:local",
		"docker-dev-shell": "docker exec -it stricture-dev /bin/bash",
		"docker-mysql-start": "bash ./start-mysql.sh",
		"docker-mysql-stop": "bash ./stop-mysql.sh",
		"docker-postgresql-start": "bash ./start-postgresql.sh",
		"docker-postgresql-stop": "bash ./stop-postgresql.sh",
		"docker-mssql-start": "bash ./start-mssql.sh",
		"docker-mssql-stop": "bash ./stop-mssql.sh"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/stevenvelozo/stricture.git"
	},
	"keywords": [
		"ddl",
		"microddl",
		"schema",
		"code-generator",
		"mysql",
		"meadow"
	],
	"author": "Steven Velozo <steven@velozo.com>",
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/stevenvelozo/stricture/issues"
	},
	"devDependencies": {
		"quackage": "^1.1.0"
	},
	"dependencies": {
		"async": "^3.2.6",
		"blessed": "^0.1.81",
		"fable": "^3.1.63",
		"jsonfile": "^6.2.0",
		"line-by-line": "0.1.4",
		"mkdirp": "^3.0.1",
		"pict": "^1.0.357",
		"pict-application": "^1.0.33",
		"pict-service-commandlineutility": "^1.0.19",
		"pict-terminalui": "^0.0.3",
		"pict-view": "^1.0.67",
		"underscore": "^1.13.7"
	},
	"mocha": {
		"diff": true,
		"extension": [
			"js"
		],
		"package": "./package.json",
		"reporter": "spec",
		"slow": "75",
		"timeout": "10000",
		"ui": "tdd",
		"watch-files": [
			"source/**/*.js",
			"test/**/*.js"
		],
		"watch-ignore": [
			"lib/vendor"
		]
	}
}
